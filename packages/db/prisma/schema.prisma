generator client {
    provider     = "prisma-client"
    output       = "../src/generated/prisma"
    moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User{
  id        String @id @default(uuid())
  email     String @unique
  password  String
  name      String?
  photo     String?
  rooms     Room[]
  chats     Chat[]
}

model Room{
  id        Int @id @default(autoincrement())
  slug      String
  createdAt DateTime @default(now())
  adminId   String
  admin     User @relation(fields: [adminId], references: [id])
  chat      Chat[]
  roomState RoomState?
}

model Chat{
  id      Int     @id @default(autoincrement())
  roomId  Int 
  message String
  userId  String  
  room    Room    @relation(fields: [roomId], references: [id])
  user    User    @relation(fields: [userId], references: [id])


}

model RoomState {
  id        Int      @id @default(autoincrement())
  roomId    Int      @unique
  snapshot  Json
  updatedAt DateTime @updatedAt
  room      Room     @relation(fields: [roomId], references: [id])
}
